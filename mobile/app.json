{
  "expo": {
    "name": "Trading Terminal",
    "slug": "trading-terminal",
    "version": "1.0.0",
    "scheme": "trading-terminal",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d0d0f",
    "ios": {
      "bundleIdentifier": "com.terminal.trading",
      "supportsTablet": true
    },
    "android": {
      "package": "com.terminal.trading",
      "adaptiveIcon": {
        "backgroundColor": "#0d0d0f"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
